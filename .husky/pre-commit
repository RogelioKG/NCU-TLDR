#!/bin/sh
set -e

# Colors
RED='\033[1;31m'
GREEN='\033[1;32m'
BLUE='\033[1;34m'
YELLOW='\033[1;33m'
NC='\033[0m'

print_msg() {
    printf "$1$2${NC}\n"
}

print_msg "$GREEN" "🚀 [Pre-commit] Starting Checks..."

# Check if backend files are changed
if git diff --cached --name-only | grep -q "^backend/"; then
    print_msg "$BLUE" "🔄 [Backend] Checking..."
    cd backend

    # 1. Lint & Format Check
    RUFF_FAILED=0

    if ! uv run ruff check .; then
        RUFF_FAILED=1
        echo ""
        print_msg "$YELLOW" "💡 [Backend] To auto-fix lint issues, run:"
        print_msg "$NC" "    cd backend && uv run ruff check --fix . && cd .."
    fi

    if ! uv run ruff format --check .; then
        RUFF_FAILED=1
        echo ""
        print_msg "$YELLOW" "💡 [Backend] To auto-fix formatting, run:"
        print_msg "$NC" "    cd backend && uv run ruff format . && cd .."
    fi

    if [ "$RUFF_FAILED" -eq 1 ]; then
        echo ""
        print_msg "$RED" "❌ [Backend] Ruff checks failed. Please fix the issues above and re-commit."
        exit 1
    fi

    # 2. Check requirements.txt Consistency (auto-fix to avoid shell encoding issues on Windows)
    if ! uv export --locked --no-hashes --no-annotate --format requirements.txt | diff -q requirements.txt - > /dev/null 2>&1; then
        print_msg "$YELLOW" "⚠️  [Backend] requirements.txt is out of sync, auto-fixing..."
        uv export --locked --no-hashes --no-annotate --format requirements.txt > requirements.txt
        git add requirements.txt
        print_msg "$GREEN" "✅ [Backend] requirements.txt updated and staged."
    fi
    
    cd ..
else
    print_msg "$YELLOW" "⏭️  [Backend] No changes detected, skipping..."
fi

# Check if frontend files are changed
if git diff --cached --name-only | grep -q "^frontend/"; then
    print_msg "$BLUE" "🔄 [Frontend] Checking..."
    cd frontend

    # Lint Check
    pnpm run lint

    cd ..
else
    print_msg "$YELLOW" "⏭️  [Frontend] No changes detected, skipping..."
fi

print_msg "$GREEN" "✅ [Pre-commit] All checks passed! Committing..."
